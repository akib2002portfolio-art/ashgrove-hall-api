# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://hall_user:secret@localhost:5432/hall_management
# Or individual fields:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hall_management
# DB_USER=hall_user
# DB_PASSWORD=secret

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# ── App ──────────────────────────────────────────────
HALL_NAME=Ashgrove Hall
VISITOR_MAX_HOURS=2
FRONTEND_URL=http://localhost:5173
